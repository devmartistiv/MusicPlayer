<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="10dp">

    <ImageView
        android:id="@+id/image_list"
        android:layout_width="75dp"
        android:layout_height="75dp"
        android:src="@drawable/rec_list_image"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="@id/image_list"
        app:layout_constraintLeft_toRightOf="@+id/image_list"
        app:layout_constraintTop_toTopOf="@id/image_list">

        <TextView
            android:id="@+id/track_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="15dp"

            android:text="Название"
            android:textColor="@color/textColorPrimary"
            android:textSize="24sp" />

        <TextView
            android:id="@+id/track_author"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="15dp"

            android:text="Автор"
            android:textColor="@color/textColorSecondary"
            android:textSize="18sp" />
    </LinearLayout>
    <ImageView
        android:id="@+id/download"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:src="@drawable/download"
        app:layout_constraintBottom_toBottomOf="@id/image_list"
        app:layout_constraintTop_toTopOf="@id/image_list"
        app:layout_constraintEnd_toEndOf="parent"
        app:tint="#929292"/>

</androidx.constraintlayout.widget.ConstraintLayout>