    <androidx.appcompat.widget.AppCompatImageButton

        android:id="@id/exo_play"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginTop="40dp"
        android:background="@drawable/bg_play_button"
        android:padding="19dp"
        android:paddingEnd="15dp"
        android:scaleType="fitCenter"
        android:src="@drawable/play_music_icon"
        app:layout_constraintCircleRadius="20dp"
        app:layout_constraintEnd_toEndOf="parent"

        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/exo_progress" />

    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@id/exo_pause"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginTop="40dp"
        android:background="@drawable/bg_play_button"
        android:padding="15dp"
        android:paddingEnd="15dp"
        android:scaleType="fitCenter"
        android:src="@drawable/track_pause"
        app:layout_constraintCircleRadius="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/exo_progress" />

    <androidx.appcompat.widget.AppCompatImageButton
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginStart="10dp"
        android:layout_marginTop="40dp"
        android:background="@null"
        android:padding="10dp"
        android:scaleType="centerCrop"
        android:src="@drawable/next_track_icon"
        app:layout_constraintStart_toEndOf="@+id/exo_play"
        app:layout_constraintTop_toBottomOf="@id/exo_progress" />

    <androidx.appcompat.widget.AppCompatImageButton
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginStart="10dp"
        android:layout_marginTop="40dp"
        android:background="@null"
        android:padding="10dp"
        android:scaleType="centerCrop"
        android:src="@drawable/previous_track_icon"
        app:layout_constraintEnd_toStartOf="@+id/exo_play"
        app:layout_constraintTop_toBottomOf="@id/exo_progress" />
</androidx.constraintlayout.widget.ConstraintLayout>