<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/track_image"
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:layout_marginTop="100dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:src="@drawable/rec_list_image" />
    <ImageView
        android:id="@+id/author_image"
        android:layout_width="50dp"
        android:layout_height="50dp"
        app:layout_constraintEnd_toStartOf="@id/track_name"
        app:layout_constraintTop_toTopOf="@id/track_name"
        tools:src="@drawable/rec_list_image" />
    <TextView
        android:paddingStart="10dp"
        android:id="@+id/track_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="45dp"
        android:text="Название трэка"
        android:textColor="@color/textColorPrimary"
        android:textSize="20sp"
        app:layout_constraintStart_toStartOf="@id/track_image"
        app:layout_constraintTop_toBottomOf="@id/track_image" />

    <TextView
        android:paddingStart="10dp"
        android:id="@+id/track_author"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Автор"
        android:textSize="15sp"
        app:layout_constraintStart_toStartOf="@id/track_name"
        app:layout_constraintTop_toBottomOf="@id/track_name" />

    <androidx.appcompat.widget.AppCompatSeekBar
        android:id="@+id/track_progress"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="40dp"
        android:layout_marginTop="15dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/track_author" />

    <TextView
        android:id="@+id/time_passed"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:text="00:00"
        android:textSize="12sp"
        app:layout_constraintStart_toStartOf="@id/track_progress"
        app:layout_constraintTop_toBottomOf="@id/track_progress" />

    <TextView
        android:id="@+id/total_duration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:text="00:00"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="@id/track_progress"
        app:layout_constraintTop_toBottomOf="@id/track_progress" />

    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/play"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginTop="40dp"
        android:background="@drawable/bg_play_button"
        android:padding="19dp"
        android:paddingEnd="15dp"
        android:scaleType="fitCenter"
        android:src="@drawable/play_music_icon"
        app:layout_constraintCircleRadius="20dp"
        app:layout_constraintEnd_toEndOf="parent"

        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/track_progress" />

    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/pause"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginTop="40dp"
        android:background="@drawable/bg_play_button"
        android:padding="15dp"
        android:paddingEnd="15dp"
        android:scaleType="fitCenter"
        android:src="@drawable/track_pause"
        android:visibility="gone"
        app:layout_constraintCircleRadius="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/track_progress" />

    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/next"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginStart="10dp"
        android:layout_marginTop="40dp"
        android:background="@null"
        android:padding="10dp"
        android:scaleType="centerCrop"
        android:src="@drawable/next_track_icon"
        app:layout_constraintStart_toEndOf="@+id/play"
        app:layout_constraintTop_toBottomOf="@id/track_progress" />

    <androidx.appcompat.widget.AppCompatImageButton
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginStart="10dp"
        android:layout_marginTop="40dp"
        android:background="@null"
        android:padding="10dp"
        android:scaleType="centerCrop"
        android:src="@drawable/previous_track_icon"
        app:layout_constraintEnd_toStartOf="@+id/play"
        app:layout_constraintTop_toBottomOf="@id/track_progress" />
</androidx.constraintlayout.widget.ConstraintLayout>